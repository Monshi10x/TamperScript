{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "checkJs": false,
    "allowJs": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "paths": {
      "*": ["*", "./*"]
    }
  },
  "include": [
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.js"
  ]
}